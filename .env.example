# ── Meridant Matrix — environment template ────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# ── Database paths (container-internal paths) ─────────────────────────────────
# Split mode (preferred): two separate DBs — framework IP vs client data
MERIDANT_FRAMEWORKS_DB_PATH=/app/data/meridant_frameworks.db
MERIDANT_ASSESSMENTS_DB_PATH=/app/data/meridant.db

# Legacy single-DB fallback (still works if split paths are not set)
# TMM_DB_PATH=/app/data/e2caf.db

# ── Anthropic API ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514   # optional — overrides default model
ANTHROPIC_MAX_RETRIES=3                    # optional
ANTHROPIC_RETRY_DELAY=2.0                  # optional — seconds between retries
ANTHROPIC_RETRY_MAX_DELAY=20.0             # optional — max retry backoff cap in seconds
ANTHROPIC_RETRY_JITTER=0.75                # optional — random jitter added per retry (seconds)

# Step 3 question-generation throttle/hardening
QUESTION_GEN_CALL_DELAY_SECONDS=1.5        # optional — pause between capability requests
QUESTION_GEN_CAPABILITY_ATTEMPTS=2         # optional — per-capability attempts before skipping

# ── App settings ───────────────────────────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=30                 # optional

# ── Fly.io deployment note ─────────────────────────────────────────────────────
# When deploying to Fly.io:
#   fly secrets set ANTHROPIC_API_KEY=sk-ant-...   (never bake into image)
#   DB files must be on a persistent volume — not committed to git or the image
#   Framework DB flows:  local → Fly.io  (push after version releases)
#   Assessment DB flows: Fly.io → local  (pull for review/backup only)
